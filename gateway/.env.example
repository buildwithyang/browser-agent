# 复制为 .env 并填入真实值：  cp .env.example .env

# OpenAI 或任意 OpenAI 兼容服务的 API key。
OPENAI_API_KEY=

# 接口地址；留空用 OpenAI 官方地址。示例：
#   https://api.moonshot.ai/v1                 (Moonshot / Kimi)
#   https://ark.cn-beijing.volces.com/api/v3   (火山方舟 / 豆包)
#   https://api.deepseek.com/v1                (DeepSeek)
#   http://localhost:11434/v1                  (本地 Ollama)
OPENAI_BASE_URL=

# 模型 id（短输入用，要快要省）。例：moonshot-v1-8k / gpt-4o-mini
AGENT_BRIDGE_MODEL=gpt-4o-mini

# 长输入路由：prompt 超过 AGENT_BRIDGE_ROUTE_THRESHOLD 字符时改用该模型，
# 让大页面 / 简历匹配也能装下。留空则不路由。
# 阈值是“字符”：中文约 1 字符=1 token，英文约 4 字符=1 token，
# 中文偏多时阈值要设低(8k token 给中文大约只够 ~6000 字符)。
# 例(Moonshot)：long=moonshot-v1-128k（稳妥）或 moonshot-v1-32k（英文为主更省）
AGENT_BRIDGE_MODEL_LONG=
AGENT_BRIDGE_ROUTE_THRESHOLD=6000

# ============================================================================
# 以下为云端 / 多租户部署所需（登录 + 简历）。仅本地单用户跑摘要时可不填，
# 此时简历匹配回退到本地文件 AGENT_BRIDGE_CV_PATH（data/cv/cv.pdf）。
# ============================================================================

# ---- 数据库（默认 SQLite；PostgreSQL 用 postgresql://...）-------------------
DATABASE_URL=sqlite:///./data/agent_bridge.sqlite3
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30

# ---- 登录态 cookie ---------------------------------------------------------
# 签名 session cookie 的 HMAC secret；生产务必替换。
AUTH_SESSION_SECRET=change-me-in-prod
# HTTPS 部署设 true，否则浏览器不回传 Secure cookie。
AUTH_COOKIE_SECURE=false
# 登录成功后浏览器最终跳回的前端地址（简历管理页）。也用于 CORS 放行。
# 前端经 Vite /api 代理访问网关，所以这里填前端自身地址。
# 纯 127.0.0.1 本地：http://127.0.0.1:5173/
# 用 dev-start（dev 域名）：http://dev.buildwithyang.com:5173/
AUTH_FRONTEND_REDIRECT_URL=http://127.0.0.1:5173/

# ---- Casdoor OAuth ---------------------------------------------------------
CASDOOR_ENDPOINT=
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
# 必须和 Casdoor 应用 Redirect URLs 完全一致。登录经前端 /api 代理发起，cookie 落在
# 前端源上，所以回调也要回到「前端 + /api/auth/callback」，而不是网关直连地址。
# 纯 127.0.0.1 本地：http://127.0.0.1:5173/api/auth/callback
# 用 dev-start（dev 域名）：http://dev.buildwithyang.com:5173/api/auth/callback
CASDOOR_REDIRECT_URI=http://127.0.0.1:5173/api/auth/callback
CASDOOR_HTTP_TIMEOUT=15

# ---- 对象存储（简历文件）---------------------------------------------------
# fake（本地联调，不真正存储、无法解析）/ oss（需 uv sync --extra oss）。
STORAGE_PROVIDER=fake
# OSS bucket 域名或 CDN，与 object_key 拼成访问地址。
ASSET_BASE_URL=
ASSET_HTTP_TIMEOUT=30
RESUME_MAX_BYTES=10485760
OSS_REGION=cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
