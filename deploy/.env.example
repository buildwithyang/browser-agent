# Agent Bridge Docker 部署配置（多租户云端 / 内置 Postgres / HTTP）。
# 复制为 deploy/.env 并填入真实值：  cp .env.example .env
# 本文件被 compose 用于 ${...} 插值，同时经 env_file 注入到 gateway 容器。
# .env 含密钥，已被 .gitignore 忽略，不要提交。

# ============================================================================
# Postgres（db 服务 + gateway 的 DATABASE_URL 都用这三个值拼出来）
# ============================================================================
POSTGRES_USER=agentbridge
POSTGRES_PASSWORD=            # 必填：数据库密码
POSTGRES_DB=agentbridge

# ============================================================================
# 对外入口
# ============================================================================
# 对外统一入口端口（宿主机映射到 web/nginx 80）。用户与扩展都访问 http://<host>:<WEB_PORT>。
WEB_PORT=17321

# ============================================================================
# LLM 分层路由（按 prompt 字符长度选 {url, key, model}）
# ============================================================================
# JSON map：键 = 该层能容纳的最大 prompt 字符数；"default" = 兜底大模型（无上限，必填）。
# 按 prompt 长度选「阈值 ≥ 长度 的最小那层」，超过所有阈值就用 default。每层可跨厂。
# 最小配置：AGENT_BRIDGE_MODELS='{"default": {"url":"https://api.moonshot.ai/v1","key":"sk-xxx","model":"moonshot-v1-128k"}}'
AGENT_BRIDGE_MODELS='{
  "6000":   {"url": "https://api.deepseek.com/v1", "key": "sk-deepseek-xxx", "model": "deepseek-chat"},
  "31000":  {"url": "https://api.moonshot.ai/v1",  "key": "sk-moonshot-xxx", "model": "moonshot-v1-32k"},
  "default":{"url": "https://api.moonshot.ai/v1",  "key": "sk-moonshot-xxx", "model": "moonshot-v1-128k"}
}'

# ============================================================================
# 多租户登录态（云端必填）
# ============================================================================
# 签名 session cookie 的 HMAC secret，务必换成随机长串（如 openssl rand -hex 32）。
AUTH_SESSION_SECRET=          # 必填，换掉
# 只跑 HTTP 时为 false；上 HTTPS 后改 true，否则浏览器不回传 Secure cookie。
AUTH_COOKIE_SECURE=false
# 登录成功后跳回的前端地址，必须是用户实际访问 web 的地址（host:WEB_PORT）。也用于 CORS 放行。
AUTH_FRONTEND_REDIRECT_URL=http://YOUR_HOST:17321/

# ============================================================================
# Casdoor OAuth
# ============================================================================
CASDOOR_ENDPOINT=
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
# 必须和 Casdoor 应用后台的 Redirect URLs 完全一致；登录经前端 /api 代理，回调要回到「前端 + /api/auth/callback」。
CASDOOR_REDIRECT_URI=http://YOUR_HOST:17321/api/auth/callback
CASDOOR_HTTP_TIMEOUT=15

# ============================================================================
# 对象存储（简历文件）—— 云端用阿里云 OSS
# ============================================================================
# fake（不真正存储、无法解析，仅联调）/ oss（真实存储与解析）。
STORAGE_PROVIDER=oss
# OSS bucket 域名或 CDN，与 object_key 拼成访问地址。
ASSET_BASE_URL=
ASSET_HTTP_TIMEOUT=30
RESUME_MAX_BYTES=10485760
OSS_REGION=cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ============================================================================
# 扩展鉴权 / 限流
# ============================================================================
# 扩展 bearer token 有效期（秒），默认 30 天。
EXTENSION_TOKEN_TTL_SECONDS=2592000


# ============================================================================
# Task 相关配置（网关）
# ============================================================================
# /tasks 强制登录（扩展带 bearer token / 网页带 cookie）。
REQUIRE_AUTH=true
# 单用户 /tasks 限流：窗口内最大次数，0=不限流；窗口秒数默认 1 天。
TASK_RATE_LIMIT_MAX=0
TASK_RATE_LIMIT_WINDOW_SECONDS=86400
