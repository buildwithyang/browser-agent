{
  "name": "agent-bridge-extension",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:markdown-vendor": "node scripts/sync-markdown-vendor.mjs",
    "test": "node --test",
    "package": "npm run sync:markdown-vendor && bash package.sh",
    "test:package": "npm run package && unzip -p dist/agent-bridge-extension.zip config.js | grep -q 'BUILD_ENV = \"production\"' && node --test scripts/verify-package.mjs"
  },
  "dependencies": {
    "dompurify": "3.4.12",
    "marked": "18.0.6"
  },
  "devDependencies": {
    "jsdom": "29.1.1"
  }
}
